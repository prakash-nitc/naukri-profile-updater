# ──────────────────────────────────────────────
# Naukri Profile Auto-Updater Configuration
# ──────────────────────────────────────────────

# Required: Your Naukri login credentials
NAUKRI_EMAIL=your_email@example.com
NAUKRI_PASSWORD=your_password_here

# ── Schedule ──────────────────────────────────
# Set ONE of these (not both):
# UPDATE_EVERY_MINUTES=240
# UPDATE_AT_HHMM=09:30

# ── Browser Settings ─────────────────────────
# HEADLESS=true
# PROFILE_URL=https://www.naukri.com/mnjuser/profile
# LAUNCH_MINIMIZED=true
# HIDE_BROWSER_WINDOW=true

# ── Session Management ───────────────────────
# USE_SAVED_SESSION=true
# SAVE_SESSION_AFTER_LOGIN=true
# SESSION_FILE=naukri_session.json
# SESSION_MAX_AGE_HOURS=24

# ── Name Rotation (optional) ─────────────────
# Toggles your display name between two variants each cycle
# to trigger a profile freshness signal.
# ENABLE_RANDOM_NAME_UPDATE=true
# NAME_VARIANT_1=Your Name
# NAME_VARIANT_2=Your name

# ── Logging ───────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FILE=naukri_updater.log

# ── Retry & Recovery ─────────────────────────
# MAX_RETRIES=3
# MAX_CONSECUTIVE_FAILURES=5

# ── Notifications (all optional) ─────────────
# Webhook (Slack, Discord, or any URL accepting JSON POST)
# NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/...

# Telegram
# NOTIFY_TELEGRAM_BOT_TOKEN=your_bot_token
# NOTIFY_TELEGRAM_CHAT_ID=your_chat_id

# Email (SMTP)
# NOTIFY_EMAIL_SMTP_HOST=smtp.gmail.com
# NOTIFY_EMAIL_SMTP_PORT=587
# NOTIFY_EMAIL_FROM=you@gmail.com
# NOTIFY_EMAIL_PASSWORD=your_app_password
# NOTIFY_EMAIL_TO=you@gmail.com
